# Environment variables for ProofPack
# Copy this file to .env.local and fill in the values.
# Never commit real keys to source control.
#
# For production: replace test keys with live keys from the Stripe Dashboard → Developers → API keys.

# ── Analytics & Search Console ────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave unset or empty to disable analytics entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token.
# Paste the value from the "HTML tag" verification method in Search Console.
# Leave unset or empty until you are ready to verify.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Payment gate (Stripe) ──────────────────────────────────────────────────
# Set to "true" to enable the $4.99 payment gate on PDF export.
# When "false" (default), the payment step is skipped (useful for local dev).
NEXT_PUBLIC_PAYMENT_GATE_ENABLED=false

# Stripe secret key.
# Use sk_test_... for local development/testing.
# Use sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price ID for the evidence-pack product ($4.99, one-time).
# Create this in the Stripe dashboard: Catalog → Products → Add product → one-time, 4.99 USD.
# Test IDs start with price_test_..., live IDs start with price_...
STRIPE_PRICE_ID=price_test_...

# Stripe webhook secret — verifies webhook payloads from Stripe.
# Obtain from the Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# Required if you add a /api/webhook route; leave unset otherwise.
STRIPE_WEBHOOK_SECRET=

# Public base URL — used to build Stripe success/cancel redirect URLs.
# Production:  https://proofpack.pro
# Local:       http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
